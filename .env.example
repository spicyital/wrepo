# WRepo environment configuration
# `npm install` copies this file to `.env` automatically if `.env` does not exist.
# Keep local defaults for development. For production, set APP_URL and
# NEXTAUTH_URL to https://wrepo.org and replace all placeholder secrets.

# --- Application ---
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=WRepo
APP_DESCRIPTION=A self-hosted academic paper repository
WEB_PORT=3000

# --- Database ---
# For docker-compose, hostname is `db`. For local dev, use `localhost`.
DATABASE_URL=postgresql://wrepo:wrepo@localhost:5432/wrepo?schema=public
POSTGRES_USER=wrepo
POSTGRES_PASSWORD=wrepo
POSTGRES_DB=wrepo
POSTGRES_PORT=5432

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=dev-only-change-me-before-production
NEXTAUTH_URL=http://localhost:3000
# NextAuth uses this for server-side callbacks behind reverse proxies/tunnels.
# In production docker-compose, the service default is http://web:3000.
NEXTAUTH_URL_INTERNAL=http://localhost:3000

# --- Storage ---
STORAGE_DRIVER=local
# Local app path for non-docker runs.
STORAGE_LOCAL_PATH=./storage
# Host path mounted into the web container at /app/storage in docker-compose.
STORAGE_HOST_PATH=./storage

# --- Search ---
SEARCH_DRIVER=postgres

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL=info

# --- Admin bootstrap (optional; used by scripts/create-admin.ts) ---
ADMIN_EMAIL=admin@wrepo.org
ADMIN_PASSWORD=change-me-please
ADMIN_NAME=WRepo Administrator
# Set to 1 to run scripts/create-admin.ts automatically on container start.
ADMIN_BOOTSTRAP=0

# --- Cloudflare Tunnel production settings ---
# Create a remotely-managed tunnel in Cloudflare Zero Trust and paste the token.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_LOGLEVEL=info

# --- Backups ---
BACKUP_ROOT=./backups
